# ── Flowork monorepo — keep CODE, never commit DATA / artifacts / secrets ──

# Build artifacts (compiled binaries ONLY — NOT the OS overlay scripts under
# os/rootfs-overlay/usr/local/bin, which are source and MUST be committed).
/os/out/
/os/.work/
/desktop/bin/
# Local dev-only OS Creator GUI (os/builder) — removed from the PUBLIC repo on purpose
# (commit 95d204d): it bakes owner state/tokens, so it stays LOCAL and is never pushed.
/os/builder/
/os/flasher/flowork-usb-maker
/os/mesh-rendezvous/flowork-rendezvous-*
/agent/flowork-gui
/agent/bin/flowork-cli
/agent/bin/flowork-mcp
/agent/bin/flowork-mcp-web
/agent/bin/flowork-tui
/router/flow_router
/router/flow-router-bin
*.test
*.exe

# User / runtime DATA (sacred — never replaced by updates)
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite-shm
*.sqlite-wal
/router/brain/
/agent/agents/*/workspace/
*.fwpack

# OS image artifacts
*.img
*.iso
*.squashfs
*.initramfs*
*.vmlinuz
*.model-disk*

# Secrets — NEVER commit (audit before every push)
*.key
*.pem
!**/update-pub.pem
flowork.local.env
*.env_bak
GITHUB_ACCOUNT.MD
KERNEL_FREEZE*
data.key
update.key
*.bundle
*.fwagent/workspace/
# Runtime data dirs leaked into repo root (owner DB/secrets live in $HOME, NOT repo)
/.flowork/
/.agents/

# Editor / OS cruft
.DS_Store
*.swp
node_modules/

# llama-server binary/symlink — local build artifact, bundled per-OS by make-distributable (NOT in git; #10 portable)
/router/bin/

# CGM dev scratch (one-time ingestion tools + intermediates — NEVER ship)
_scratch_cgm/
**/_scratch_cgm/
router/out/
KERNEL_FREEZE.md

# Sidecar tools (lock/tools.md) — KEEP source (main.go/tool.json/go.mod), IGNORE compiled
# native binaries (rebuild via tools/build-tools.sh) + runtime state + per-agent private tools.
tools/.health.json
tools/.tombstones.json
tools/_private/
tools/*/*
!tools/*/*.go
!tools/*/*.json
!tools/*/*.mod
!tools/*/*.sum
!tools/*/*.md
